{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenda-flow.local/schemas/planning-result.schema.json",
  "title": "PlanningResult",
  "type": "object",
  "required": ["planning_result_id", "status"],
  "properties": {
    "planning_result_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["ready", "conflict", "needs_user_decision"]
    },
    "recommended_event": { "$ref": "calendar-event.schema.json" },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "conflicting_event_title": { "type": "string" },
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" }
        }
      }
    },
    "user_decisions_required": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "options"],
        "properties": {
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
